# GenClaw credentials template — copy to .env and fill in. .env is gitignored.

# Anthropic backbone for the LLM agent + VLM reviewer (default: Claude-Opus-4.6).
ANTHROPIC_API_KEY=
# Optional: point at an Anthropic-compatible proxy/gateway instead of the default.
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Image generator (default: Gemini-3.1-Flash-Image).
GOOGLE_API_KEY=
# Optional: point at a Gemini-compatible proxy/gateway instead of the default.
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com

# Multi-round search for knowledge grounding (Mind-Bench).
TAVILY_API_KEY=

# Optional model overrides (defaults align with the paper, ADR 0004).
# GENCLAW_AGENT_MODEL=claude-opus-4-6
# GENCLAW_REVIEWER_MODEL=claude-opus-4-6
# GENCLAW_GENERATOR_MODEL=gemini-3.1-flash-image
